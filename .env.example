# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
BRAVE_API_KEY=...

# ── Database ──────────────────────────────────────────────────────────────────
# Local: leave unset (defaults to data/pipeline.db)
# Railway: set to /data/pipeline.db (persistent volume mounted at /data)
# DB_PATH=/data/pipeline.db

# ── Email Report (Gmail) ──────────────────────────────────────────────────────
# 1. Enable 2FA on your Gmail account
# 2. Go to myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
# 4. Paste the 16-character password (no spaces) as SMTP_PASS
EMAIL_TO=dailyasia9@gmail.com
EMAIL_FROM=your-sender@gmail.com
SMTP_USER=your-sender@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
